# Optional: absolute path to PostgreSQL bin directory if tools are not in PATH.
# Example: C:\Program Files\PostgreSQL\17\bin
PG_BIN_DIR=

# Source PostgreSQL database (READ-ONLY for this workflow)
SOURCE_PGHOST=
SOURCE_PGPORT=
SOURCE_PGDATABASE=
SOURCE_PGUSER=
SOURCE_PGPASSWORD=
# Typical values: require, verify-ca, verify-full, disable
SOURCE_PGSSLMODE=require

# Recipient PostgreSQL database (must already exist)
RECIPIENT_PGHOST=
RECIPIENT_PGPORT=
RECIPIENT_PGDATABASE=
RECIPIENT_PGUSER=
RECIPIENT_PGPASSWORD=
# Set only when the recipient requires SSL
RECIPIENT_PGSSLMODE=

# Optional: number of parallel jobs for pg_restore (custom format supports this)
# Use 1 if unsure.
RESTORE_JOBS=1
